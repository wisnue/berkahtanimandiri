# Email Configuration (Optional - for expiring document notifications)

# SMTP Server Configuration
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password
EMAIL_FROM=KTH BTM <noreply@kthbtm.org>

# Application URL (for email links)
APP_URL=http://localhost:5173

# Notes:
# - For Gmail: Use App Password (not your regular password)
#   Generate at: https://myaccount.google.com/apppasswords
# - For other providers: Check their SMTP settings
# - EMAIL_SECURE should be 'true' for port 465, 'false' for port 587
# - Notification scheduler runs daily at 08:00 AM
# - Checks documents expiring within 30 days
# - Sends email to admin, ketua, and sekretaris roles
