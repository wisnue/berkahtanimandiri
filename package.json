{
  "name": "kth-btm-monorepo",
  "version": "1.0.0",
  "private": true,
  "description": "Sistem Informasi KTH Berkah Tani Mandiri - KHDPK & PNBP Compliance",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\" --names \"backend,frontend\" --prefix-colors \"bgBlue.bold,bgMagenta.bold\"",
    "dev:frontend": "npm --prefix apps/frontend run dev",
    "dev:backend": "npm --prefix apps/backend run dev",
    "build": "npm run build:frontend && npm run build:backend",
    "build:frontend": "npm --prefix apps/frontend run build",
    "build:backend": "npm --prefix apps/backend run build",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "db:seed": "npm --prefix apps/backend run db:seed",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint .",
    "format": "prettier --write .",
    "pm2:start": "npx pm2 start ecosystem.config.js",
    "pm2:stop": "npx pm2 stop ecosystem.config.js",
    "pm2:restart": "npx pm2 restart ecosystem.config.js",
    "pm2:delete": "npx pm2 delete ecosystem.config.js",
    "pm2:logs": "npx pm2 logs",
    "pm2:monit": "npx pm2 monit",
    "pm2:status": "npx pm2 status"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^22.10.2",
    "concurrently": "^9.2.1",
    "cross-env": "^7.0.3",
    "eslint": "^9.17.0",
    "jest": "^29.7.0",
    "pm2": "^5.4.2",
    "prettier": "^3.4.2",
    "ts-jest": "^29.2.5",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "dependencies": {
    "@vercel/analytics": "^1.6.1"
  }
}
