# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/kth_btm
DB_HOST=localhost
DB_PORT=5432
DB_NAME=kth_btm
DB_USER=postgres
DB_PASSWORD=password

# Server
NODE_ENV=development
PORT=5000
API_URL=http://localhost:5000

# Session
SESSION_SECRET=your-super-secret-session-key-change-this-in-production

# CORS
CORS_ORIGIN=http://localhost:5173

# File Upload
MAX_FILE_SIZE=10485760
UPLOAD_DIR=./uploads

# PNBP
PNBP_TARIF_PER_HA=15000
TAHUN_PNBP=2025

# Security
BCRYPT_ROUNDS=10
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION=900000

# 2FA
OTP_ISSUER=KTH-BTM
OTP_WINDOW=1
